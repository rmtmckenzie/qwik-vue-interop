{
  "name": "qwik-vue-interop",
  "version": "1.0.0",
  "repository": "https://github.com/rmtmckenzie/qwik-vue-interop",
  "license": "MIT",
  "description": "Render Vue components inside Qwik applications with reactivity and selective hydration.",
  "main": "./lib/index.qwik.mjs",
  "qwik": "./lib/index.qwik.mjs",
  "types": "./lib-types/index.qwik.d.ts",
  "exports": {
    ".": {
      "import": "./lib/index.qwik.mjs",
      "require": "./lib/index.qwik.cjs",
      "types": "./lib-types/index.qwik.d.ts"
    }
  },
  "files": [
    "lib",
    "lib-types",
    "src"
  ],
  "type": "module",
  "scripts": {
    "build": "vite build --mode lib && tsc --emitDeclarationOnly",
    "build.lib": "vite build --mode lib",
    "build.types": "tsc --emitDeclarationOnly"
  },
  "peerDependencies": {
    "@builder.io/qwik": "^1.20.0",
    "vue": "^3.4.0"
  },
  "devDependencies": {
    "@builder.io/qwik": "^1.20.0",
    "@types/node": "^20.0.0",
    "@vitejs/plugin-vue": "^5.0.0",
    "typescript": "^5.3.0",
    "vite": "^7.0.0",
    "vue": "^3.4.0"
  }
}
